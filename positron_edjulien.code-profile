{"name":"positron_edjulien","icon":"smiley","settings":"{\"settings\":\"{\\r\\n\\r\\n// APPARENCE GLOBALE -----------------------------------------------------------\\r\\n\\r\\n    \\\"workbench.colorTheme\\\": \\\"Material Night Purple\\\",\\r\\n    \\\"workbench.iconTheme\\\": \\\"material-icon-theme\\\",\\r\\n    \\\"workbench.productIconTheme\\\": \\\"fluent-icons\\\",\\r\\n\\r\\n    \\\"window.title\\\": \\\"${activeEditorFull}${separator}${rootName}\\\",\\r\\n\\r\\n// COLORATION SYNTAXIQUE -------------------------------------------------------\\r\\n\\r\\n    \\\"editor.tokenColorCustomizations\\\": {\\r\\n        \\\"textMateRules\\\": [\\r\\n            {\\r\\n                \\\"name\\\": \\\"Text and Source Base\\\",\\r\\n                \\\"scope\\\": [\\r\\n                    \\\"text\\\",\\r\\n                    \\\"source\\\"\\r\\n                ],\\r\\n                \\\"settings\\\": {\\r\\n                    \\\"foreground\\\": \\\"#CDD3DE\\\"\\r\\n                }\\r\\n            },\\r\\n            {\\r\\n                \\\"name\\\": \\\"Variable\\\",\\r\\n                \\\"scope\\\": [\\r\\n                    \\\"variable\\\",\\r\\n                    \\\"variable.parameter\\\",\\r\\n                    \\\"source.python\\\",\\r\\n                    \\\"source.python meta.function-call.arguments.python\\\"\\r\\n                ],\\r\\n                \\\"settings\\\": {\\r\\n                    \\\"foreground\\\": \\\"#ffffff\\\"\\r\\n                }\\r\\n            },\\r\\n            {\\r\\n                \\\"name\\\": \\\"Constant Numeric\\\",\\r\\n                \\\"scope\\\": [\\r\\n                    \\\"constant.numeric\\\"\\r\\n                ],\\r\\n                \\\"settings\\\": {\\r\\n                    \\\"foreground\\\": \\\"#ff7869\\\"\\r\\n                }\\r\\n            },\\r\\n            {\\r\\n                \\\"name\\\": \\\"Constant Language\\\",\\r\\n                \\\"scope\\\": [\\r\\n          